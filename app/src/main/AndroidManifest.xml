<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ═══════════════════════════════════════════════════
         PERMISSÕES DE MÍDIA
         Android 13+ (API 33): permissões granulares por tipo
         Android 12 e abaixo: READ_EXTERNAL_STORAGE legado
    ════════════════════════════════════════════════════ -->

    <!-- Android 13+ — fotos -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        android:minSdkVersion="33" />

    <!-- Android 13+ — vídeos -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        android:minSdkVersion="33" />

    <!-- Android 14+ — acesso parcial à galeria (usuário escolhe fotos específicas) -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
        android:minSdkVersion="34" />

    <!-- Android 12 e abaixo — leitura de armazenamento externo -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Acesso a todos os arquivos (necessário para pastas ocultas do WhatsApp no Android 11+) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Necessário para ler thumbnails do MediaStore -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <queries>
        <package android:name="com.miui.mediaeditor" />
        <package android:name="com.miui.gallery" />
        <package android:name="com.xiaomi.scanner" />
        <package android:name="com.miui.extraphoto" />
        <intent>
            <action android:name="android.intent.action.EDIT" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="com.miui.gallery.action.EDIT_DOCUMENT" />
            <data android:mimeType="image/*" />
        </intent>
    </queries>

    <application
        android:name=".HyperGalleryApplication"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HyperGallery"
        android:largeHeap="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.HyperGallery">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
